# peasy-pdf-rs — PDF merge, split, rotate, compress (Rust)
# Theme: Nord
# Generated for AgentGIF demo collection

Output demo.gif
Set Shell "zsh"
Set Theme "nord"
Set Width 800
Set Height 500
Set FontSize 14
Set Padding 20
Set TypingSpeed 50ms

# Show package info
Type "# peasy-pdf-rs — PDF merge, split, rotate, compress for Rust"
Enter
Type "# peasypdf.com"
Enter
Sleep 500ms

# Run the demo
Type "cargo run --example demo 2>/dev/null"
Enter
Sleep 5s
